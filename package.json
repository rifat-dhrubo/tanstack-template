		"orval": "^7.13.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"qs": "^6.14.0",
		"react": "^19.2.6",
		"react-day-picker": "^9.11.2",
		"react-dom": "^19.2.6",
		"react-hook-form": "^7.66.0",
		"react-markdown": "^10.1.0",
		"react-paginate": "^8.3.0",
		"recharts": "2.15.4",
		"semantic-release": "^25.0.3",
		"sonner": "^2.0.7",
