		"@tanstack/react-start": "^1.168.13",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/router-plugin": "^1.168.11",
		"@types/nprogress": "^0.2.3",
		"@types/qs": "^6.14.0",
		"axios": "^1.12.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
