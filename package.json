{
	"name": "tanstack-template",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --port 3210",
		"build": "vite build && tsc",
		"serve": "vite preview",
		"test": "vitest run",
		"lint": "eslint",
		"lint:fix": "eslint --fix --cache && prettier --write .",
		"format": "prettier",
		"type:check": "tsc --noEmit",
		"check": "prettier --write . && eslint --fix",
		"prepare": "husky",
		"preinstall": "npx only-allow pnpm",
		"commit": "cz",
		"generate": "orval --config orval.config.mjs && prettier --write src/generated && eslint --fix --cache && tsc --noEmit",
		"lucide:generate": "tsx generate-lucide-install.ts"
	},
	"dependencies": {
